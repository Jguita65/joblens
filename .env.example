# ─────────────────────────────────────────────────────────────
# JobLens — variables de entorno de ejemplo
# Copia este archivo a `.env` y rellena los valores.
# NUNCA subas tu `.env` real al repositorio.
# ─────────────────────────────────────────────────────────────

# OBLIGATORIA en producción. Clave para firmar los JWT de sesión (Auth.js).
# Genera una con:  npx auth secret   —o—   openssl rand -base64 32
AUTH_SECRET="genera-una-clave-aleatoria-larga"

# OPCIONAL. Hash bcrypt de la contraseña del usuario de prueba.
# Si no la defines, se usa el hash por defecto de "test1234".
# Genera uno con:  node -e "console.log(require('bcryptjs').hashSync('test1234',10))"
# AUTH_TEST_PASSWORD_HASH="$2b$10$..."

# OPCIONAL. Cadena de conexión a Postgres.
# Si NO la defines, la app funciona igual y guarda el historial en localStorage.
# Si la defines, el historial y el registro de usuarios se persisten en Postgres.
# DATABASE_URL="postgresql://usuario:password@host:5432/joblens?schema=public"

# OPCIONAL. IA local con Ollama para la reescritura asistida.
# Solo funciona si la app se ejecuta en un equipo que pueda alcanzar Ollama
# (por defecto, tu propia máquina en desarrollo). En un deploy remoto no se usa.
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="qwen3.5:9b"
